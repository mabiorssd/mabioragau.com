{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/og-image",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(bot|crawler|spider|facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|TelegramBot|Slackbot|Discordbot|SkypeUriPreview|vkShare|W3C_Validator|redditbot|Applebot|flipboard|tumblr|bitlybot|nuzzel|Embedly|quora link preview|showyoubot|outbrain|pinterest|Slack|Slack-ImgProxy|googlebot|Googlebot|AdsBot|SemrushBot|AhrefsBot|MJ12bot|DotBot|BLEXBot|HTTrack|magpie-crawler|Pingdom).*"
        }
      ],
      "destination": "https://zrvzcsdxbhzwfabvndbo.supabase.co/functions/v1/og-image"
    },
    {
      "source": "/blog/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(bot|crawler|spider|facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|TelegramBot|Slackbot|Discordbot|SkypeUriPreview|vkShare|W3C_Validator|redditbot|Applebot|flipboard|tumblr|bitlybot|nuzzel|Embedly|quora link preview|showyoubot|outbrain|pinterest|Slack|Slack-ImgProxy|googlebot|Googlebot|AdsBot|SemrushBot|AhrefsBot|MJ12bot|DotBot|BLEXBot|HTTrack|magpie-crawler|Pingdom).*"
        }
      ],
      "destination": "https://zrvzcsdxbhzwfabvndbo.supabase.co/functions/v1/og-blog?slug=:slug"
    },
    {
      "source": "/blog",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(bot|crawler|spider|facebookexternalhit|Facebot|Twitterbot|LinkedInBot|WhatsApp|TelegramBot|Slackbot|Discordbot|SkypeUriPreview|vkShare|W3C_Validator|redditbot|Applebot|flipboard|tumblr|bitlybot|nuzzel|Embedly|quora link preview|showyoubot|outbrain|pinterest|Slack|Slack-ImgProxy|googlebot|Googlebot|AdsBot|SemrushBot|AhrefsBot|MJ12bot|DotBot|BLEXBot|HTTrack|magpie-crawler|Pingdom).*"
        }
      ],
      "destination": "https://zrvzcsdxbhzwfabvndbo.supabase.co/functions/v1/og-blog"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.gpteng.co https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https://zrvzcsdxbhzwfabvndbo.supabase.co wss://zrvzcsdxbhzwfabvndbo.supabase.co https://ai.gateway.lovable.dev; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'" }
      ]
    }
  ]
}
